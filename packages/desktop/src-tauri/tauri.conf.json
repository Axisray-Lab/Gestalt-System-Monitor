{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Gestalt System Monitor",
  "version": "0.1.0",
  "identifier": "com.gestalt-system.monitor",
  "build": {
    "beforeDevCommand": "npm run dev -w @gsm/web",
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5180"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "dock",
        "title": "Gestalt System Monitor",
        "url": "deck.html",
        "width": 1280,
        "height": 320,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "visible": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
